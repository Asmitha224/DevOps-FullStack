<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card stat-blue">
          <div class="stat-icon"><i class="fas fa-file-pdf"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= totalPapers %></div>
            <div class="stat-label">Total Papers</div>
          </div>
          <div class="stat-trend"><i class="fas fa-arrow-up"></i></div>
        </div>
        <div class="stat-card stat-purple">
          <div class="stat-icon"><i class="fas fa-users"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= totalUsers %></div>
            <div class="stat-label">Total Users</div>
          </div>
          <div class="stat-trend"><i class="fas fa-arrow-up"></i></div>
        </div>
        <div class="stat-card stat-teal">
          <div class="stat-icon"><i class="fas fa-cloud-upload-alt"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= recentUploads %></div>
            <div class="stat-label">Recent Uploads</div>
          </div>
          <div class="stat-trend"><i class="fas fa-clock"></i></div>
        </div>
        <div class="stat-card stat-orange">
          <div class="stat-icon"><i class="fas fa-hdd"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= storageUsedMB %> <span>MB</span></div>
            <div class="stat-label">Storage Used</div>
          </div>
          <div class="stat-trend"><i class="fas fa-database"></i></div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="charts-grid">
        <div class="chart-card">
          <div class="chart-header">
            <h3>Papers Uploaded Per Month</h3>
            <span class="chart-badge">Last 12 months</span>
          </div>
          <div class="chart-wrap">
            <canvas id="barChart"></canvas>
          </div>
        </div>
        <div class="chart-card">
          <div class="chart-header">
            <h3>Papers by Category</h3>
            <span class="chart-badge">All time</span>
          </div>
          <div class="chart-wrap chart-wrap-pie">
            <canvas id="pieChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Recent Uploads Table -->
      <div class="table-card">
        <div class="table-header">
          <h3>Recent Uploads</h3>
          <a href="/papers" class="btn btn-sm btn-outline">View All</a>
        </div>
        <% if (recentPapers.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <p>No papers uploaded yet. <a href="/papers/create">Upload the first one!</a></p>
          </div>
        <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Year</th>
                <th>Uploaded By</th>
                <th>Date</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% recentPapers.forEach(paper => { %>
              <tr>
                <td class="td-title"><%= paper.title.length > 50 ? paper.title.substring(0,50)+'…' : paper.title %></td>
                <td><%= paper.author %></td>
                <td><span class="cat-badge"><%= paper.category %></span></td>
                <td><%= paper.year %></td>
                <td><%= paper.uploadedBy ? paper.uploadedBy.name : 'Unknown' %></td>
                <td><%= new Date(paper.createdAt).toLocaleDateString() %></td>
                <td><a href="/papers/<%= paper._id %>" class="btn btn-xs btn-ghost"><i class="fas fa-eye"></i></a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/js/dashboard.js"></script>
<script>
  const monthLabels = <%- monthLabels %>;
  const monthData = <%- monthData %>;
  const categoryLabels = <%- categoryLabels %>;
  const categoryData = <%- categoryData %>;
  initDashboardCharts(monthLabels, monthData, categoryLabels, categoryData);
</script>
<script src="/js/app.js"></script>
</body></html>
