<%- include('../partials/head') %>
<div class="auth-page">
  <div class="auth-left">
    <div class="auth-branding">
      <div class="auth-logo"><i class="fas fa-atom"></i></div>
      <h1>ResearchHub</h1>
      <p>Join thousands of researchers managing their academic work in one place.</p>
      <ul class="auth-features">
        <li><i class="fas fa-check"></i> Free to get started</li>
        <li><i class="fas fa-check"></i> Secure file storage</li>
        <li><i class="fas fa-check"></i> Powerful categorization</li>
        <li><i class="fas fa-check"></i> Role-based access control</li>
      </ul>
    </div>
  </div>
  <div class="auth-right">
    <div class="auth-card">
      <h2>Create account</h2>
      <p class="auth-subtitle">Get started with ResearchHub today</p>
      <%- include('../partials/flash') %>
      <form action="/auth/register" method="POST" class="auth-form">
        <div class="form-group">
          <label for="name">Full Name</label>
          <div class="input-icon">
            <i class="fas fa-user"></i>
            <input type="text" id="name" name="name" placeholder="Dr. Jane Smith" required autocomplete="name" />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email address</label>
          <div class="input-icon">
            <i class="fas fa-envelope"></i>
            <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email" />
          </div>
        </div>
        <div class="form-group">
          <label for="password">Password <span class="hint">(min 6 characters)</span></label>
          <div class="input-icon">
            <i class="fas fa-lock"></i>
            <input type="password" id="password" name="password" placeholder="••••••••" required />
            <button type="button" class="toggle-password" onclick="togglePass(this)"><i class="fas fa-eye"></i></button>
          </div>
        </div>
        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <div class="input-icon">
            <i class="fas fa-lock"></i>
            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required />
          </div>
        </div>
        <div class="form-group">
          <label for="role">Account Role</label>
          <div class="input-icon">
            <i class="fas fa-shield-alt"></i>
            <select id="role" name="role">
              <option value="user">User — Upload & manage papers</option>
              <option value="admin">Admin — Full system access</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-full">
          <i class="fas fa-user-plus"></i> Create Account
        </button>
      </form>
      <p class="auth-link">Already have an account? <a href="/auth/login">Sign in</a></p>
    </div>
  </div>
</div>
<script>
function togglePass(btn) {
  const input = btn.closest('.input-icon').querySelector('input');
  const icon = btn.querySelector('i');
  input.type = input.type === 'password' ? 'text' : 'password';
  icon.classList.toggle('fa-eye');
  icon.classList.toggle('fa-eye-slash');
}
</script>
</body></html>
