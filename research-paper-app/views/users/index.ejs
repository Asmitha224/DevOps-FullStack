<%- include('../partials/head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-body">
      <%- include('../partials/flash') %>
      <div class="table-card">
        <div class="table-header">
          <h3><i class="fas fa-users-cog"></i> User Management</h3>
          <span class="badge-count"><%= users.length %> users</span>
        </div>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Role</th>
                <th>Papers Uploaded</th>
                <th>Last Login</th>
                <th>Member Since</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
              <tr>
                <td>
                  <div class="user-cell">
                    <% if (user.profilePicture) { %>
                      <img src="<%= user.profilePicture %>" class="user-avatar-sm" alt="avatar" />
                    <% } else { %>
                      <span class="user-initials-sm"><%= user.name.charAt(0).toUpperCase() %></span>
                    <% } %>
                    <span><%= user.name %></span>
                    <% if (user._id.toString() === session.userId) { %>
                      <span class="badge-you">You</span>
                    <% } %>
                  </div>
                </td>
                <td><%= user.email %></td>
                <td>
                  <span class="badge-role <%= user.role %>"><%= user.role %></span>
                </td>
                <td><%= user.papersUploaded %></td>
                <td><%= user.lastLogin ? new Date(user.lastLogin).toLocaleString() : 'Never' %></td>
                <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
                <td class="td-actions">
                  <a href="/users/<%= user._id %>/edit" class="btn btn-xs btn-ghost" title="Change Role">
                    <i class="fas fa-user-shield"></i>
                  </a>
                  <% if (user._id.toString() !== session.userId) { %>
                  <form action="/users/<%= user._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirmDelete('user <%= user.name %> and all their papers')">
                    <button type="submit" class="btn btn-xs btn-danger" title="Delete User">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body></html>
